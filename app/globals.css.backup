@import "tailwindcss";

:root {
  --ink: #090909;
  --muted: rgba(9, 9, 9, 0.48);
  --border: rgba(9, 9, 9, 0.075);
  --surface: #ffffff;
  --soft-surface: #f7f8fb;
  --blue: #2563eb;
  --violet: #7c3aed;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  overflow-x: hidden;
  background: var(--surface);
  color: var(--ink);
  font-family: Arial, Helvetica, sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

::selection {
  background: var(--ink);
  color: white;
}

.site-shell {
  min-height: 100vh;
  overflow: hidden;
  background: white;
}

/* NAVBAR */

.site-header {
  position: fixed;
  inset: 0 0 auto;
  z-index: 100;
  padding: 18px 22px;
  transition:
    padding 400ms ease,
    transform 400ms ease;
}

.navbar {
  display: flex;
  max-width: 1360px;
  min-height: 72px;
  margin: 0 auto;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px 0 14px;
  border: 1px solid transparent;
  border-radius: 24px;
  transition:
    background 450ms ease,
    border-color 450ms ease,
    box-shadow 450ms ease,
    backdrop-filter 450ms ease;
}

.site-header-scrolled {
  padding-top: 10px;
}

.site-header-scrolled .navbar {
  border-color: rgba(9, 9, 9, 0.07);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 18px 70px rgba(31, 45, 78, 0.09);
  backdrop-filter: blur(24px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-mark {
  position: relative;
  display: grid;
  width: 44px;
  height: 44px;
  place-items: center;
  overflow: hidden;
  border-radius: 15px;
  background: var(--ink);
  color: white;
  font-size: 11px;
  font-weight: 800;
}

.brand-mark span {
  position: absolute;
}

.brand-mark span:first-child {
  transform: translate(-4px, -2px);
}

.brand-mark span:last-child {
  transform: translate(5px, 4px);
  color: #93c5fd;
}

.brand-copy {
  display: flex;
  flex-direction: column;
}

.brand-copy strong {
  font-size: 14px;
  letter-spacing: 0.18em;
}

.brand-copy small {
  margin-top: 3px;
  color: rgba(9, 9, 9, 0.36);
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.desktop-nav {
  display: flex;
  align-items: center;
  gap: 38px;
}

.desktop-nav a {
  position: relative;
  color: rgba(9, 9, 9, 0.48);
  font-size: 12px;
  font-weight: 700;
  transition: color 300ms ease;
}

.desktop-nav a::after {
  position: absolute;
  right: 0;
  bottom: -8px;
  left: 0;
  height: 1px;
  background: var(--ink);
  content: "";
  transform: scaleX(0);
  transform-origin: right;
  transition: transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
}

.desktop-nav a:hover {
  color: var(--ink);
}

.desktop-nav a:hover::after {
  transform: scaleX(1);
  transform-origin: left;
}

.nav-cta,
.primary-button {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 999px;
  background: var(--ink);
  color: white;
}

.nav-cta {
  min-height: 44px;
  gap: 14px;
  padding: 0 20px;
  font-size: 12px;
  font-weight: 700;
  transition:
    transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 400ms ease;
}

.nav-cta::before,
.primary-button::before {
  position: absolute;
  inset: 0;
  background: linear-gradient(110deg, var(--blue), var(--violet));
  content: "";
  transform: translateY(104%);
  transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
}

.nav-cta > span,
.primary-button > span {
  position: relative;
  z-index: 1;
}

.nav-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 40px rgba(37, 99, 235, 0.22);
}

.nav-cta:hover::before,
.primary-button:hover::before {
  transform: translateY(0);
}

.button-arrow {
  transition: transform 350ms ease;
}

.nav-cta:hover .button-arrow,
.primary-button:hover .button-arrow {
  transform: translateX(4px);
}

/* HERO */

.hero-section {
  position: relative;
  min-height: 100svh;
  overflow: hidden;
  background: white;
}

.hero-background {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.42;
  background-image:
    linear-gradient(rgba(9, 9, 9, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(9, 9, 9, 0.035) 1px, transparent 1px);
  background-size: 76px 76px;
  mask-image: linear-gradient(to bottom, black 0%, transparent 78%);
}

.hero-noise {
  position: absolute;
  inset: 0;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

.pointer-light {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    circle 360px at var(--pointer-x) var(--pointer-y),
    rgba(147, 197, 253, 0.2),
    rgba(196, 181, 253, 0.08) 40%,
    transparent 72%
  );
  transition: background 80ms linear;
}

.light-beam {
  position: absolute;
  width: 520px;
  height: 720px;
  border-radius: 50%;
  filter: blur(110px);
  opacity: 0.28;
}

.light-beam-left {
  top: -280px;
  left: -150px;
  background: #bfdbfe;
  animation: beamLeft 12s ease-in-out infinite;
}

.light-beam-right {
  right: -170px;
  bottom: -300px;
  background: #ddd6fe;
  animation: beamRight 14s ease-in-out infinite;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  width: min(1360px, calc(100% - 44px));
  min-height: 100svh;
  margin: 0 auto;
  flex-direction: column;
  justify-content: center;
  padding: 150px 36px 42px;
}

.hero-badge {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  gap: 10px;
  align-self: center;
  padding: 8px 13px 8px 9px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: 0 10px 30px rgba(25, 39, 74, 0.06);
  color: rgba(9, 9, 9, 0.48);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  backdrop-filter: blur(18px);
}

.badge-status {
  display: grid;
  width: 23px;
  height: 23px;
  place-items: center;
  border-radius: 50%;
  background: #eff6ff;
}

.badge-pulse {
  position: relative;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--blue);
}

.badge-pulse::after {
  position: absolute;
  inset: -5px;
  border: 1px solid rgba(37, 99, 235, 0.28);
  border-radius: 50%;
  content: "";
  animation: statusPulse 2s ease-out infinite;
}

.hero-title {
  margin: 32px 0 0;
  text-align: center;
  font-size: clamp(72px, 10vw, 150px);
  font-weight: 700;
  line-height: 0.78;
  letter-spacing: -0.085em;
}

.hero-line {
  display: block;
}

.hero-line-middle {
  margin-left: -10%;
  color: rgba(9, 9, 9, 0.19);
  font-weight: 600;
}

.hero-gradient-line {
  margin-left: 8%;
  padding-bottom: 0.12em;
  background: linear-gradient(
    100deg,
    #090909 3%,
    #2563eb 40%,
    #7c3aed 67%,
    #090909 96%
  );
  background-size: 220% auto;
  background-clip: text;
  color: transparent;
  animation: gradientFlow 8s linear infinite;
}

.hero-lower {
  display: grid;
  width: min(900px, 100%);
  margin: 44px auto 0;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 60px;
}

.hero-description {
  max-width: 560px;
  margin: 0;
  color: var(--muted);
  font-size: 16px;
  font-weight: 500;
  line-height: 1.85;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.primary-button,
.secondary-button {
  min-height: 54px;
  padding: 0 25px;
  font-size: 12px;
  font-weight: 800;
}

.primary-button {
  gap: 18px;
  box-shadow: 0 18px 45px rgba(9, 9, 9, 0.16);
  transition:
    transform 450ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 450ms ease;
}

.primary-button:hover {
  transform: translateY(-4px) scale(1.015);
  box-shadow: 0 26px 60px rgba(37, 99, 235, 0.25);
}

.secondary-button {
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.74);
  transition:
    transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 400ms ease,
    box-shadow 400ms ease;
  backdrop-filter: blur(18px);
}

.secondary-button:hover {
  border-color: rgba(9, 9, 9, 0.17);
  transform: translateY(-4px);
  box-shadow: 0 18px 42px rgba(25, 39, 74, 0.09);
}

/* HERO ORBIT */

.hero-orbit {
  position: absolute;
  top: 52%;
  left: 50%;
  width: 790px;
  height: 360px;
  pointer-events: none;
  transform: translate(-50%, -50%);
}

.orbit-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border: 1px solid rgba(37, 99, 235, 0.1);
  border-radius: 50%;
  transform: translate(-50%, -50%) rotate(-8deg);
}

.orbit-ring-one {
  width: 760px;
  height: 270px;
}

.orbit-ring-two {
  width: 590px;
  height: 205px;
  border-color: rgba(124, 58, 237, 0.09);
  transform: translate(-50%, -50%) rotate(12deg);
}

.orbit-core {
  position: absolute;
  top: 50%;
  left: 50%;
  display: grid;
  width: 58px;
  height: 58px;
  place-items: center;
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.55);
  box-shadow:
    0 25px 80px rgba(37, 99, 235, 0.2),
    inset 0 1px 0 white;
  font-size: 11px;
  font-weight: 900;
  backdrop-filter: blur(22px);
  transform: translate(-50%, -50%);
}

.hero-card {
  position: absolute;
  width: 185px;
  padding: 16px;
  border: 1px solid rgba(9, 9, 9, 0.07);
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.69);
  box-shadow:
    0 24px 70px rgba(37, 56, 100, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(22px);
}

.hero-card-top {
  display: flex;
  align-items: center;
  gap: 7px;
  color: rgba(9, 9, 9, 0.38);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.card-indicator {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1);
}

.hero-card strong {
  display: block;
  margin-top: 15px;
  font-size: 26px;
  letter-spacing: -0.06em;
}

.hero-card p {
  margin: 5px 0 0;
  color: rgba(9, 9, 9, 0.35);
  font-size: 10px;
  font-weight: 600;
}

.hero-card-support {
  top: 16px;
  left: -40px;
  animation: floatOne 6s ease-in-out infinite;
}

.hero-card-automation {
  top: 30px;
  right: -20px;
  animation: floatTwo 7s ease-in-out infinite;
}

.hero-card-team {
  right: 80px;
  bottom: -34px;
  animation: floatThree 6.5s ease-in-out infinite;
}

.hero-footer {
  display: flex;
  margin-top: auto;
  align-items: flex-end;
  justify-content: space-between;
  padding-top: 58px;
}

.capability-list {
  display: flex;
  flex-wrap: wrap;
  gap: 22px;
}

.capability-list span {
  display: flex;
  align-items: center;
  gap: 8px;
  color: rgba(9, 9, 9, 0.37);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.04em;
}

.capability-list i {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(9, 9, 9, 0.25);
}

.scroll-indicator {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(9, 9, 9, 0.36);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.scroll-line {
  position: relative;
  display: block;
  width: 1px;
  height: 34px;
  overflow: hidden;
  background: rgba(9, 9, 9, 0.12);
}

.scroll-line i {
  position: absolute;
  top: -14px;
  left: 0;
  width: 1px;
  height: 14px;
  background: var(--ink);
  animation: scrollLine 2s ease-in-out infinite;
}

/* REVEALS */

.hero-reveal {
  opacity: 0;
  transform: translateY(34px);
  animation: revealHero 1.05s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.reveal-delay-1 {
  animation-delay: 80ms;
}

.reveal-delay-2 {
  animation-delay: 150ms;
}

.reveal-delay-3 {
  animation-delay: 240ms;
}

.reveal-delay-4 {
  animation-delay: 330ms;
}

.reveal-delay-5 {
  animation-delay: 450ms;
}

.reveal-delay-6 {
  animation-delay: 620ms;
}

.reveal-delay-7 {
  animation-delay: 760ms;
}

/* TRUST */

.trust-strip {
  border-top: 1px solid rgba(9, 9, 9, 0.055);
  border-bottom: 1px solid rgba(9, 9, 9, 0.055);
  background: rgba(255, 255, 255, 0.84);
}

.trust-inner {
  display: flex;
  max-width: 1360px;
  min-height: 96px;
  margin: auto;
  align-items: center;
  justify-content: space-between;
  padding: 0 58px;
}

.trust-inner p {
  margin: 0;
  color: rgba(9, 9, 9, 0.34);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.trust-items {
  display: flex;
  align-items: center;
  gap: 24px;
  color: rgba(9, 9, 9, 0.42);
  font-size: 12px;
  font-weight: 800;
}

.trust-items i {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: rgba(9, 9, 9, 0.2);
}

/* SERVICES */

.services-section {
  position: relative;
  padding: 150px 0;
  background:
    radial-gradient(circle at 50% 0%, rgba(219, 234, 254, 0.45), transparent 29%),
    #f8f9fb;
}

.section-container {
  width: min(1280px, calc(100% - 48px));
  margin: auto;
}

.section-heading {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: end;
  gap: 80px;
}

.section-kicker {
  margin: 0 0 22px;
  color: var(--blue);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.section-heading h2 {
  margin: 0;
  font-size: clamp(60px, 7vw, 96px);
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -0.075em;
}

.section-heading h2 span {
  color: rgba(9, 9, 9, 0.22);
}

.section-intro {
  max-width: 570px;
  margin: 0;
  color: var(--muted);
  font-size: 17px;
  font-weight: 500;
  line-height: 1.8;
}

.services-grid {
  display: grid;
  margin-top: 88px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.service-panel {
  position: relative;
  display: flex;
  min-height: 520px;
  overflow: hidden;
  flex-direction: column;
  justify-content: space-between;
  padding: 34px;
  border: 1px solid rgba(9, 9, 9, 0.065);
  border-radius: 34px;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 24px 80px rgba(32, 49, 91, 0.06);
  transition:
    transform 600ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 600ms ease,
    border-color 600ms ease;
}

.service-panel-light {
  position: absolute;
  inset: 0;
  opacity: 0;
  background:
    radial-gradient(circle at 20% 5%, rgba(191, 219, 254, 0.72), transparent 34%),
    radial-gradient(circle at 90% 90%, rgba(221, 214, 254, 0.5), transparent 36%);
  transition: opacity 700ms ease;
}

.service-panel:hover {
  z-index: 2;
  border-color: rgba(37, 99, 235, 0.14);
  box-shadow: 0 40px 120px rgba(32, 49, 91, 0.13);
  transform: translateY(-10px);
}

.service-panel:hover .service-panel-light {
  opacity: 1;
}

.service-panel-top,
.service-panel-content {
  position: relative;
  z-index: 1;
}

.service-panel-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.service-number {
  display: grid;
  width: 54px;
  height: 54px;
  place-items: center;
  border: 1px solid rgba(9, 9, 9, 0.07);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.7);
  color: rgba(9, 9, 9, 0.4);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.12em;
  backdrop-filter: blur(16px);
}

.service-arrow {
  display: grid;
  width: 48px;
  height: 48px;
  place-items: center;
  border: 1px solid rgba(9, 9, 9, 0.07);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  color: rgba(9, 9, 9, 0.45);
  transition:
    transform 500ms cubic-bezier(0.22, 1, 0.36, 1),
    background 500ms ease,
    color 500ms ease;
}

.service-panel:hover .service-arrow {
  background: var(--ink);
  color: white;
  transform: rotate(45deg);
}

.service-eyebrow {
  margin: 0 0 15px;
  color: var(--blue);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.service-panel h3 {
  max-width: 530px;
  margin: 0;
  font-size: clamp(38px, 4vw, 58px);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.06em;
}

.service-description {
  max-width: 540px;
  margin: 25px 0 0;
  color: var(--muted);
  font-size: 14px;
  font-weight: 500;
  line-height: 1.8;
}

.service-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 28px;
}

.service-tags span {
  padding: 9px 13px;
  border: 1px solid rgba(9, 9, 9, 0.07);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  color: rgba(9, 9, 9, 0.43);
  font-size: 9px;
  font-weight: 800;
  backdrop-filter: blur(14px);
}

.preview-section {
  display: grid;
  min-height: 55vh;
  place-items: center;
  border-top: 1px solid rgba(9, 9, 9, 0.05);
  background: white;
}

.preview-section p {
  color: rgba(9, 9, 9, 0.2);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.22em;
  text-transform: uppercase;
}

.anchor-section {
  min-height: 1px;
}

/* ANIMATIONS */

@keyframes revealHero {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes gradientFlow {
  to {
    background-position: 220% center;
  }
}

@keyframes statusPulse {
  from {
    opacity: 1;
    transform: scale(0.55);
  }

  to {
    opacity: 0;
    transform: scale(1.4);
  }
}

@keyframes beamLeft {
  0%,
  100% {
    transform: translate(0, 0);
  }

  50% {
    transform: translate(110px, 85px);
  }
}

@keyframes beamRight {
  0%,
  100% {
    transform: translate(0, 0);
  }

  50% {
    transform: translate(-120px, -70px);
  }
}

@keyframes floatOne {
  0%,
  100% {
    transform: translateY(0) rotate(-2deg);
  }

  50% {
    transform: translateY(-14px) rotate(1deg);
  }
}

@keyframes floatTwo {
  0%,
  100% {
    transform: translateY(0) rotate(2deg);
  }

  50% {
    transform: translateY(16px) rotate(-1deg);
  }
}

@keyframes floatThree {
  0%,
  100% {
    transform: translateY(0) rotate(1deg);
  }

  50% {
    transform: translateY(-12px) rotate(-2deg);
  }
}

@keyframes scrollLine {
  0% {
    transform: translateY(0);
  }

  100% {
    transform: translateY(52px);
  }
}

/* RESPONSIVE */

@media (max-width: 1050px) {
  .desktop-nav {
    display: none;
  }

  .hero-title {
    font-size: clamp(70px, 12vw, 120px);
  }

  .hero-orbit {
    width: 640px;
  }

  .orbit-ring-one {
    width: 620px;
  }

  .orbit-ring-two {
    width: 500px;
  }

  .hero-card-support {
    left: 20px;
  }

  .hero-card-automation {
    right: 20px;
  }

  .hero-lower {
    grid-template-columns: 1fr;
    gap: 26px;
    text-align: center;
  }

  .hero-description {
    margin: auto;
  }

  .hero-actions {
    justify-content: center;
  }

  .section-heading {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}

@media (max-width: 760px) {
  .site-header {
    padding: 12px;
  }

  .navbar {
    min-height: 64px;
    padding-right: 10px;
  }

  .brand-copy small {
    display: none;
  }

  .nav-cta {
    min-height: 40px;
    padding: 0 15px;
  }

  .nav-cta span:first-child {
    display: none;
  }

  .hero-content {
    width: calc(100% - 24px);
    padding: 126px 8px 28px;
  }

  .hero-title {
    margin-top: 30px;
    font-size: clamp(58px, 19vw, 88px);
    line-height: 0.84;
  }

  .hero-line-middle,
  .hero-gradient-line {
    margin-left: 0;
  }

  .hero-lower {
    margin-top: 34px;
  }

  .hero-description {
    max-width: 410px;
    font-size: 14px;
    line-height: 1.75;
  }

  .hero-actions {
    width: 100%;
    flex-direction: column;
  }

  .primary-button,
  .secondary-button {
    width: min(330px, 100%);
  }

  .hero-orbit {
    display: none;
  }

  .hero-footer {
    margin-top: 62px;
    align-items: center;
    flex-direction: column;
    gap: 30px;
  }

  .capability-list {
    justify-content: center;
  }

  .trust-inner {
    min-height: 126px;
    padding: 28px 24px;
    flex-direction: column;
    justify-content: center;
    gap: 22px;
    text-align: center;
  }

  .trust-items {
    flex-wrap: wrap;
    justify-content: center;
  }

  .services-section {
    padding: 100px 0;
  }

  .section-container {
    width: calc(100% - 28px);
  }

  .section-heading h2 {
    font-size: clamp(52px, 14vw, 72px);
  }

  .section-intro {
    font-size: 15px;
  }

  .services-grid {
    margin-top: 58px;
    grid-template-columns: 1fr;
  }

  .service-panel {
    min-height: 500px;
    padding: 25px;
    border-radius: 27px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
  }
}

.premium-hero-grid {
  opacity: 0.52;
  background-image:
    linear-gradient(rgba(10, 10, 10, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(10, 10, 10, 0.03) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: linear-gradient(to bottom, black 0%, transparent 88%);
}

.premium-hero-noise {
  opacity: 0.018;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

.premium-glow {
  position: absolute;
  pointer-events: none;
  border-radius: 999px;
  filter: blur(100px);
}

.premium-glow-left {
  top: 120px;
  left: -180px;
  height: 420px;
  width: 420px;
  background: rgba(147, 197, 253, 0.25);
}

.premium-glow-right {
  top: 180px;
  right: -150px;
  height: 480px;
  width: 480px;
  background: rgba(196, 181, 253, 0.22);
}

.premium-dashboard {
  animation: premiumDashboardFloat 7s ease-in-out infinite;
}

.premium-chart-bar {
  transform-origin: bottom;
  background: linear-gradient(to top, #111827, #2563eb, #93c5fd);
  animation: premiumChartGrow 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dashboard-service-row {
  transition:
    transform 450ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 450ms ease,
    border-color 450ms ease;
}

.dashboard-service-row:hover {
  transform: translateX(5px);
  border-color: rgba(37, 99, 235, 0.15);
  box-shadow: 0 12px 35px rgba(30, 45, 85, 0.08);
}

.premium-floating-card {
  position: absolute;
  z-index: 10;
  min-width: 145px;
  border: 1px solid rgba(0, 0, 0, 0.07);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.86);
  padding: 15px 17px;
  box-shadow: 0 20px 60px rgba(30, 45, 85, 0.13);
  backdrop-filter: blur(18px);
}

.premium-floating-left {
  top: 24%;
  left: -34px;
  animation: premiumFloatLeft 5.5s ease-in-out infinite;
}

.premium-floating-right {
  right: -28px;
  bottom: 19%;
  animation: premiumFloatRight 6s ease-in-out infinite;
}

@keyframes premiumDashboardFloat {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-9px);
  }
}

@keyframes premiumChartGrow {
  from {
    opacity: 0;
    transform: scaleY(0);
  }

  to {
    opacity: 1;
    transform: scaleY(1);
  }
}

@keyframes premiumFloatLeft {
  0%,
  100% {
    transform: translateY(0) rotate(-2deg);
  }

  50% {
    transform: translateY(-12px) rotate(1deg);
  }
}

@keyframes premiumFloatRight {
  0%,
  100% {
    transform: translateY(0) rotate(2deg);
  }

  50% {
    transform: translateY(11px) rotate(-1deg);
  }
}

@media (max-width: 640px) {
  .premium-hero-grid {
    background-size: 48px 48px;
  }
}

/* Fix black CTA text visibility */
.primary-cta,
.primary-cta:link,
.primary-cta:visited {
  color: #ffffff !important;
  text-decoration: none;
}

.primary-cta span {
  color: #ffffff !important;
}

.primary-cta:hover,
.primary-cta:focus,
.primary-cta:active {
  color: #ffffff !important;
}

.services-tech-grid {
  opacity: 0.16;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: linear-gradient(to bottom, transparent, black 12%, black 88%, transparent);
}

.services-tech-glow {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  filter: blur(130px);
}

.services-tech-glow-one {
  top: 10%;
  left: -200px;
  height: 520px;
  width: 520px;
  background: rgba(37, 99, 235, 0.17);
}

.services-tech-glow-two {
  right: -220px;
  bottom: 8%;
  height: 580px;
  width: 580px;
  background: rgba(124, 58, 237, 0.14);
}

.tech-heading-gradient {
  background: linear-gradient(100deg, #ffffff, #60a5fa 42%, #a78bfa 72%, #ffffff);
  background-size: 220% auto;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: gradientFlow 8s linear infinite;
}

.tech-service-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 30px;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018));
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.07),
    0 35px 90px rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(26px);
  transition:
    transform 600ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 600ms ease,
    box-shadow 600ms ease;
}

.tech-service-card:hover {
  transform: translateY(-8px) scale(1.008);
  border-color: rgba(255, 255, 255, 0.17);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.11),
    0 45px 120px rgba(0, 0, 0, 0.42);
}

.tech-card-glow {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 700ms ease;
}

.tech-service-card:hover .tech-card-glow {
  opacity: 1;
}

.service-theme-blue .tech-card-glow {
  background: radial-gradient(circle at 10% 15%, rgba(37, 99, 235, 0.18), transparent 42%);
}

.service-theme-violet .tech-card-glow {
  background: radial-gradient(circle at 10% 15%, rgba(124, 58, 237, 0.18), transparent 42%);
}

.service-theme-cyan .tech-card-glow {
  background: radial-gradient(circle at 10% 15%, rgba(6, 182, 212, 0.17), transparent 42%);
}

.service-theme-orange .tech-card-glow {
  background: radial-gradient(circle at 10% 15%, rgba(249, 115, 22, 0.15), transparent 42%);
}

.tech-card-scan {
  position: absolute;
  top: 0;
  left: -35%;
  height: 100%;
  width: 22%;
  opacity: 0;
  transform: skewX(-18deg);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.07),
    transparent
  );
}

.tech-service-card:hover .tech-card-scan {
  opacity: 1;
  animation: techScan 1.4s ease;
}

.tech-icon-shell {
  display: flex;
  height: 52px;
  width: 52px;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.11);
  border-radius: 17px;
  background: rgba(255, 255, 255, 0.055);
  color: rgba(255, 255, 255, 0.75);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
  transition:
    transform 500ms cubic-bezier(0.22, 1, 0.36, 1),
    background 500ms ease,
    color 500ms ease;
}

.tech-service-card:hover .tech-icon-shell {
  transform: rotate(-6deg) scale(1.08);
  background: rgba(255, 255, 255, 0.11);
  color: #ffffff;
}

.tech-arrow {
  display: flex;
  height: 46px;
  width: 46px;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  color: rgba(255, 255, 255, 0.45);
  transition:
    transform 500ms cubic-bezier(0.22, 1, 0.36, 1),
    background 500ms ease,
    color 500ms ease;
}

.tech-service-card:hover .tech-arrow {
  transform: rotate(45deg);
  background: #ffffff;
  color: #050608;
}

.tech-service-tag {
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.035);
  padding: 9px 13px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.38);
  transition:
    border-color 350ms ease,
    background 350ms ease,
    color 350ms ease;
}

.tech-service-card:hover .tech-service-tag {
  border-color: rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.065);
  color: rgba(255, 255, 255, 0.62);
}

@keyframes techScan {
  from {
    left: -35%;
  }

  to {
    left: 120%;
  }
}

/* =========================
   HIGH-TECH HERO
========================= */

.hero-system {
  isolation: isolate;
}

.hero-tech-grid {
  opacity: 0.19;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
  background-size: 74px 74px;
  mask-image: linear-gradient(
    to bottom,
    black 0%,
    black 70%,
    transparent 100%
  );
}

.hero-noise {
  pointer-events: none;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.9'/%3E%3C/svg%3E");
}

.hero-orb {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  filter: blur(130px);
}

.hero-orb-blue {
  top: -250px;
  left: -180px;
  height: 620px;
  width: 620px;
  background: rgba(37, 99, 235, 0.21);
}

.hero-orb-violet {
  top: 12%;
  right: -180px;
  height: 570px;
  width: 570px;
  background: rgba(124, 58, 237, 0.18);
}

.hero-orb-cyan {
  bottom: -280px;
  left: 40%;
  height: 520px;
  width: 520px;
  background: rgba(6, 182, 212, 0.1);
}

.hero-gradient-text {
  background: linear-gradient(
    100deg,
    #ffffff 0%,
    #60a5fa 32%,
    #a78bfa 63%,
    #67e8f9 100%
  );
  background-size: 220% auto;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: heroGradientMove 8s linear infinite;
}

.hero-primary-button,
.hero-primary-button:link,
.hero-primary-button:visited {
  display: inline-flex;
  min-height: 56px;
  align-items: center;
  justify-content: center;
  gap: 13px;
  border-radius: 999px;
  background: #ffffff;
  padding: 0 26px;
  color: #050608 !important;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 18px 50px rgba(255, 255, 255, 0.1);
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 350ms ease;
}

.hero-primary-button:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 70px rgba(96, 165, 250, 0.22);
}

.hero-primary-button span,
.hero-primary-button svg {
  color: #050608 !important;
}

.hero-secondary-button,
.hero-secondary-button:link,
.hero-secondary-button:visited {
  display: inline-flex;
  min-height: 56px;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.11);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.045);
  padding: 0 26px;
  color: rgba(255, 255, 255, 0.68) !important;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  backdrop-filter: blur(18px);
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    background 350ms ease,
    border-color 350ms ease,
    color 350ms ease;
}

.hero-secondary-button:hover {
  transform: translateY(-4px);
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff !important;
}

.hero-capability {
  display: flex;
  min-height: 48px;
  align-items: center;
  gap: 9px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.025);
  padding: 0 13px;
  backdrop-filter: blur(12px);
}

.hero-capability span {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.055em;
  color: rgba(255, 255, 255, 0.38);
}

.hero-dashboard-glow {
  position: absolute;
  inset: 10%;
  border-radius: 999px;
  background: rgba(67, 97, 238, 0.3);
  filter: blur(110px);
}

.hero-command-panel {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.11);
  border-radius: 32px;
  background:
    linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.075),
      rgba(255, 255, 255, 0.022)
    );
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.09),
    0 50px 140px rgba(0, 0, 0, 0.52);
  backdrop-filter: blur(34px);
}

.hero-command-panel::after {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: "";
  background: linear-gradient(
    115deg,
    transparent 10%,
    rgba(255, 255, 255, 0.055) 35%,
    transparent 58%
  );
  transform: translateX(-110%);
  animation: heroPanelScan 8s ease-in-out infinite;
}

.hero-panel-header {
  display: flex;
  min-height: 58px;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  padding: 0 23px;
  background: rgba(255, 255, 255, 0.018);
}

.hero-data-card,
.hero-activity-card {
  border: 1px solid rgba(255, 255, 255, 0.075);
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.032);
  padding: 21px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045);
}

.hero-data-label {
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.25);
}

.hero-progress-bar {
  background: linear-gradient(90deg, #2563eb, #8b5cf6, #22d3ee);
  box-shadow: 0 0 18px rgba(96, 165, 250, 0.35);
}

.hero-chart-column {
  min-width: 5px;
  border-radius: 999px 999px 4px 4px;
  background: linear-gradient(
    to top,
    rgba(37, 99, 235, 0.28),
    rgba(96, 165, 250, 0.9)
  );
  box-shadow: 0 0 17px rgba(59, 130, 246, 0.14);
}

.hero-chart-column:nth-child(3n) {
  background: linear-gradient(
    to top,
    rgba(124, 58, 237, 0.25),
    rgba(167, 139, 250, 0.9)
  );
}

.hero-chart-column:nth-child(4n) {
  background: linear-gradient(
    to top,
    rgba(6, 182, 212, 0.22),
    rgba(103, 232, 249, 0.88)
  );
}

.hero-mini-system {
  display: flex;
  min-height: 68px;
  align-items: center;
  gap: 12px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.026);
  padding: 13px;
}

.hero-system-icon {
  display: flex;
  height: 38px;
  width: 38px;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
}

.hero-floating-card {
  position: absolute;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 11px;
  border: 1px solid rgba(255, 255, 255, 0.11);
  border-radius: 17px;
  background: rgba(13, 15, 20, 0.82);
  padding: 13px 16px;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 25px 65px rgba(0, 0, 0, 0.42);
  backdrop-filter: blur(24px);
}

.hero-floating-card-one {
  top: 17%;
  left: -10%;
}

.hero-floating-card-two {
  right: -9%;
  bottom: 16%;
}

.hero-bottom-line {
  background: linear-gradient(
    90deg,
    transparent,
    rgba(96, 165, 250, 0.45),
    rgba(167, 139, 250, 0.38),
    transparent
  );
}

@keyframes heroGradientMove {
  from {
    background-position: 0% center;
  }

  to {
    background-position: 220% center;
  }
}

@keyframes heroPanelScan {
  0%,
  60% {
    transform: translateX(-110%);
  }

  85%,
  100% {
    transform: translateX(130%);
  }
}

@media (max-width: 1180px) {
  .hero-floating-card-one {
    left: -2%;
  }

  .hero-floating-card-two {
    right: -2%;
  }
}

@media (max-width: 767px) {
  .hero-floating-card {
    display: none;
  }

  .hero-command-panel {
    border-radius: 25px;
  }

  .hero-capability span {
    font-size: 8px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-gradient-text,
  .hero-command-panel::after {
    animation: none;
  }
}

body::before{
content:"";
position:fixed;
inset:0;
pointer-events:none;
z-index:-1;

background:
radial-gradient(circle at 20% 15%, rgba(59,130,246,.12), transparent 28%),
radial-gradient(circle at 80% 20%, rgba(168,85,247,.10), transparent 30%),
radial-gradient(circle at 50% 100%, rgba(34,211,238,.06), transparent 35%);

filter:blur(90px);
opacity:.95;
}

body{
background-attachment:fixed;
}


/* =========================
   PREMIUM CUSTOM CURSOR
========================= */

@media (pointer: fine) {
  html,
  body,
  a,
  button,
  input,
  textarea,
  select {
    cursor: none !important;
  }

  .custom-cursor-dot,
  .custom-cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 99999;
    pointer-events: none;
    border-radius: 999px;
    transform: translate3d(-100px, -100px, 0);
    will-change: transform;
  }

  .custom-cursor-dot {
    width: 7px;
    height: 7px;
    margin-top: -3.5px;
    margin-left: -3.5px;
    background: #ffffff;
    box-shadow:
      0 0 12px rgba(255, 255, 255, 0.9),
      0 0 24px rgba(96, 165, 250, 0.75);
    transition:
      width 250ms ease,
      height 250ms ease,
      margin 250ms ease,
      background 250ms ease,
      opacity 250ms ease;
  }

  .custom-cursor-ring {
    width: 38px;
    height: 38px;
    margin-top: -19px;
    margin-left: -19px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.025);
    box-shadow:
      inset 0 0 18px rgba(96, 165, 250, 0.08),
      0 0 22px rgba(59, 130, 246, 0.08);
    backdrop-filter: blur(5px);
    transition:
      width 320ms cubic-bezier(0.22, 1, 0.36, 1),
      height 320ms cubic-bezier(0.22, 1, 0.36, 1),
      margin 320ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 320ms ease,
      background 320ms ease,
      box-shadow 320ms ease;
  }

  .cursor-ring-active {
    width: 62px;
    height: 62px;
    margin-top: -31px;
    margin-left: -31px;
    border-color: rgba(96, 165, 250, 0.65);
    background: rgba(59, 130, 246, 0.09);
    box-shadow:
      inset 0 0 25px rgba(96, 165, 250, 0.16),
      0 0 38px rgba(59, 130, 246, 0.18);
  }

  .cursor-dot-active {
    width: 4px;
    height: 4px;
    margin-top: -2px;
    margin-left: -2px;
    background: #60a5fa;
  }
}

@media (pointer: coarse) {
  .custom-cursor-dot,
  .custom-cursor-ring {
    display: none;
  }
}

