.section-transition{
position:relative;
height:90px;
background:
linear-gradient(
180deg,
rgba(255,255,255,1) 0%,
rgba(255,255,255,.96) 20%,
rgba(240,246,255,.75) 45%,
rgba(12,18,32,.35) 75%,
#050608 100%
);
overflow:hidden;
}

.section-transition::before{
content:"";
position:absolute;
left:50%;
top:50%;
width:900px;
height:250px;
transform:translate(-50%,-50%);
background:
radial-gradient(circle,
rgba(59,130,246,.12),
transparent 70%);
filter:blur(80px);
opacity:.7;
}



/* =========================
   PREMIUM SECTION TRANSITION
========================= */

.section-transition{
  position:relative;
  height:90px;
  overflow:hidden;

  background:linear-gradient(
    to bottom,
    #ffffff 0%,
    #fdfefe 20%,
    #f7faff 45%,
    #edf4ff 60%,
    #d8e7ff 72%,
    rgba(9,17,31,.35) 88%,
    #050608 100%
  );
}

.section-transition::before{
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(circle at 50% 35%,
    rgba(59,130,246,.10),
    transparent 65%);

  filter:blur(70px);
}

