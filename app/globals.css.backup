/* =========================
   AI DIGITAL GLOBE
========================= */

.ai-globe-wrapper {
  position: relative;
  display: flex;
  width: 100%;
  min-height: 560px;
  align-items: center;
  justify-content: center;
  isolation: isolate;
}

.ai-globe-wrapper canvas {
  position: relative;
  z-index: 2;
  max-width: 100%;
  cursor: grab;
  filter:
    drop-shadow(0 0 28px rgba(37, 99, 235, 0.3))
    drop-shadow(0 0 70px rgba(124, 58, 237, 0.16));
}

.ai-globe-wrapper canvas:active {
  cursor: grabbing;
}

.ai-globe-glow {
  position: absolute;
  z-index: 0;
  width: 70%;
  height: 70%;
  border-radius: 999px;
  background:
    radial-gradient(
      circle,
      rgba(37, 99, 235, 0.3) 0%,
      rgba(79, 70, 229, 0.16) 35%,
      transparent 70%
    );
  filter: blur(65px);
  animation: globeGlowPulse 5s ease-in-out infinite;
}

.ai-globe-wrapper::before {
  position: absolute;
  bottom: 10%;
  left: 50%;
  z-index: 1;
  width: 72%;
  height: 14%;
  content: "";
  transform: translateX(-50%);
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.24);
  filter: blur(35px);
}

.ai-globe-wrapper::after {
  position: absolute;
  bottom: 13%;
  left: 50%;
  z-index: 3;
  width: 55%;
  height: 1px;
  content: "";
  transform: translateX(-50%);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(103, 232, 249, 0.85),
    transparent
  );
  box-shadow:
    0 0 18px rgba(34, 211, 238, 0.75),
    0 0 45px rgba(37, 99, 235, 0.5);
}

.ai-globe-status {
  position: absolute;
  right: 2%;
  bottom: 14%;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 9px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999px;
  background: rgba(5, 8, 18, 0.72);
  padding: 10px 14px;
  color: rgba(255, 255, 255, 0.55);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  backdrop-filter: blur(20px);
}

.ai-globe-status span {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #34d399;
  box-shadow: 0 0 14px rgba(52, 211, 153, 0.85);
}

@keyframes globeGlowPulse {
  0%,
  100% {
    opacity: 0.7;
    transform: scale(0.94);
  }

  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

@media (max-width: 1023px) {
  .ai-globe-wrapper {
    min-height: 480px;
  }
}

@media (max-width: 640px) {
  .ai-globe-wrapper {
    min-height: 390px;
  }

  .ai-globe-status {
    right: 50%;
    bottom: 4%;
    transform: translateX(50%);
    white-space: nowrap;
  }
}

/* =========================
   WHITE HIGH-TECH HERO
========================= */

.white-tech-hero {
  isolation: isolate;
}

.white-tech-grid {
  opacity: 0.52;
  background-image:
    linear-gradient(rgba(37, 99, 235, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(37, 99, 235, 0.055) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: linear-gradient(
    to bottom,
    black,
    black 72%,
    transparent
  );
}

.white-hero-glow {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  filter: blur(120px);
}

.white-glow-one {
  top: -220px;
  left: -160px;
  width: 560px;
  height: 560px;
  background: rgba(59, 130, 246, 0.15);
}

.white-glow-two {
  top: 8%;
  right: -180px;
  width: 620px;
  height: 620px;
  background: rgba(124, 58, 237, 0.12);
}

.white-status-pill {
  display: inline-flex;
  align-items: center;
  gap: 13px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.76);
  padding: 12px 17px;
  box-shadow:
    0 16px 45px rgba(15, 23, 42, 0.055),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.white-status-pill span:last-child {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.17em;
  text-transform: uppercase;
  color: rgba(15, 23, 42, 0.48);
}

.white-status-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  background: #2563eb;
  box-shadow:
    0 0 0 4px rgba(37, 99, 235, 0.1),
    0 0 20px rgba(37, 99, 235, 0.5);
}

.white-gradient-heading {
  background: linear-gradient(
    100deg,
    #0f172a 0%,
    #2563eb 38%,
    #7c3aed 72%,
    #0891b2 100%
  );
  background-size: 220% auto;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: whiteHeadingFlow 8s linear infinite;
}

.white-primary-cta,
.white-primary-cta:link,
.white-primary-cta:visited {
  display: inline-flex;
  min-height: 58px;
  align-items: center;
  justify-content: center;
  gap: 12px;
  border-radius: 999px;
  background: linear-gradient(135deg, #2563eb, #4f46e5);
  padding: 0 27px;
  color: #ffffff !important;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 18px 45px rgba(37, 99, 235, 0.22);
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 350ms ease;
}

.white-primary-cta:hover {
  transform: translateY(-4px);
  box-shadow: 0 25px 65px rgba(37, 99, 235, 0.32);
}

.white-secondary-cta,
.white-secondary-cta:link,
.white-secondary-cta:visited {
  display: inline-flex;
  min-height: 58px;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(15, 23, 42, 0.1);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.75);
  padding: 0 27px;
  color: #0f172a !important;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 15px 40px rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(18px);
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 350ms ease,
    box-shadow 350ms ease;
}

.white-secondary-cta:hover {
  transform: translateY(-4px);
  border-color: rgba(37, 99, 235, 0.25);
  box-shadow: 0 22px 55px rgba(15, 23, 42, 0.09);
}

.white-globe-shell {
  position: relative;
  width: 100%;
  min-height: 610px;
  overflow: hidden;
  border: 1px solid rgba(37, 99, 235, 0.1);
  border-radius: 42px;
  background:
    radial-gradient(
      circle at 50% 42%,
      rgba(219, 234, 254, 0.8),
      rgba(255, 255, 255, 0.9) 52%,
      rgba(248, 250, 252, 0.96)
    );
  box-shadow:
    0 45px 110px rgba(15, 23, 42, 0.1),
    inset 0 1px 0 #ffffff;
}

.white-globe-grid {
  position: absolute;
  inset: 0;
  opacity: 0.45;
  background-image:
    linear-gradient(rgba(37, 99, 235, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(37, 99, 235, 0.055) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: radial-gradient(circle, black, transparent 72%);
}

.white-ai-globe {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.white-ai-globe canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}

.white-globe-shell::before {
  position: absolute;
  left: 50%;
  bottom: 13%;
  z-index: 1;
  width: 62%;
  height: 13%;
  content: "";
  transform: translateX(-50%);
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.16);
  filter: blur(28px);
}

.white-globe-shell::after {
  position: absolute;
  left: 50%;
  bottom: 15%;
  z-index: 3;
  width: 54%;
  height: 1px;
  content: "";
  transform: translateX(-50%);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(37, 99, 235, 0.75),
    transparent
  );
  box-shadow: 0 0 25px rgba(37, 99, 235, 0.35);
}

.globe-live-status {
  position: absolute;
  right: 24px;
  bottom: 23px;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 9px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.8);
  padding: 11px 15px;
  color: rgba(15, 23, 42, 0.52);
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  box-shadow: 0 14px 40px rgba(15, 23, 42, 0.07);
  backdrop-filter: blur(18px);
}

.globe-live-dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #10b981;
  box-shadow: 0 0 15px rgba(16, 185, 129, 0.65);
}

.globe-floating-stat {
  position: absolute;
  z-index: 5;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(37, 99, 235, 0.09);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.76);
  padding: 14px 17px;
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.075);
  backdrop-filter: blur(18px);
}

.globe-floating-stat strong {
  font-size: 19px;
  line-height: 1;
  letter-spacing: -0.04em;
  color: #0f172a;
}

.globe-floating-stat span {
  margin-top: 6px;
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(15, 23, 42, 0.38);
}

.globe-stat-one {
  top: 18%;
  left: 4%;
}

.globe-stat-two {
  top: 30%;
  right: 4%;
}

.white-capability-grid {
  display: grid;
  gap: 12px;
  margin-top: 28px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.white-capability-card {
  display: flex;
  min-height: 90px;
  align-items: center;
  gap: 14px;
  border: 1px solid rgba(15, 23, 42, 0.075);
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.76);
  padding: 17px;
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.055);
  backdrop-filter: blur(18px);
  transition:
    transform 350ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 350ms ease,
    border-color 350ms ease;
}

.white-capability-card:hover {
  transform: translateY(-5px);
  border-color: rgba(37, 99, 235, 0.18);
  box-shadow: 0 25px 60px rgba(37, 99, 235, 0.1);
}

.white-capability-icon {
  display: flex;
  width: 45px;
  height: 45px;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  border-radius: 14px;
  background: rgba(37, 99, 235, 0.08);
  color: #2563eb;
}

.white-capability-card p {
  font-size: 12px;
  font-weight: 700;
  color: #0f172a;
}

.white-capability-card span {
  display: block;
  margin-top: 4px;
  font-size: 9px;
  font-weight: 600;
  color: rgba(15, 23, 42, 0.38);
}

@keyframes whiteHeadingFlow {
  from {
    background-position: 0% center;
  }

  to {
    background-position: 220% center;
  }
}

@media (max-width: 1023px) {
  .white-globe-shell {
    min-height: 540px;
  }

  .white-capability-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .white-globe-shell {
    min-height: 420px;
    border-radius: 28px;
  }

  .globe-floating-stat {
    display: none;
  }

  .globe-live-status {
    right: 50%;
    bottom: 16px;
    transform: translateX(50%);
    white-space: nowrap;
  }

  .white-capability-grid {
    grid-template-columns: 1fr;
  }
}

/* Restore normal system cursor */
html,
body,
a,
button,
input,
textarea,
select,
[role="button"] {
  cursor: auto !important;
}

a,
button,
[role="button"] {
  cursor: pointer !important;
}

.custom-cursor-dot,
.custom-cursor-ring {
  display: none !important;
}



